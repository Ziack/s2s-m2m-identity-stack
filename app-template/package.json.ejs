{
  "name": "<%= serviceName %>",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "docker:build": "docker build -t <%= serviceName %>:local .",
    "docker:push": "echo 'configure ECR push manually — repo URI comes from terraform output ecr_repository_uri'"
  },
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "@s2s/auth-library": "<%= sdkVersion %>",
    "express": "^4.19.2",
    "pino": "^9.0.0",
    "pino-http": "^10.1.0",
    "prom-client": "^15.1.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
